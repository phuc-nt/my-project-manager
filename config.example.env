# Copy to .env and fill in. .env is gitignored — never commit real values.
# Agent holds only the OpenRouter key + runtime flags.
# Atlassian/Slack tokens live in each MCP server's own env (see deployment-guide.md §3),
# GitHub auth is via `gh auth login`. They are NOT set here.

# --- LLM provider (OpenRouter, OpenAI-compatible) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2.7
# Fallback model if the default underperforms: qwen/qwen-3.7
OPENROUTER_REFERER=https://github.com/local/my-project-manager
OPENROUTER_TITLE=my-project-manager

# --- Guardrails ---
# DRY_RUN=true -> Action Gateway logs intended writes instead of executing them.
DRY_RUN=true
# Kill switch: true -> gateway refuses ALL mutations (read + log only).
AGENT_WRITE_DISABLED=false
# Monthly OpenRouter spend cap (USD). Hard-stop at 100%, warn at the ratio below.
MONTHLY_BUDGET_USD=50
BUDGET_WARN_RATIO=0.8

# --- MCP connection (Phase 1 — agent connects to standalone servers) ---
# Transport/host/port decided in Phase 1; left blank in Phase 0.
# MCP_JIRA_URL=
# MCP_CONFLUENCE_URL=
# MCP_SLACK_URL=
