<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mpm.report.weekly</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/phucnt/workspace/my-project-manager/deploy/launchd/run-report.sh</string>
        <string>--weekly</string>
    </array>
    <!-- Weekly sprint review on Friday (Weekday 5) at 17:00. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>5</integer>
        <key>Hour</key>
        <integer>17</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/phucnt/workspace/my-project-manager/.data/cron-weekly.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/phucnt/workspace/my-project-manager/.data/cron-weekly.err.log</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
